# ========================================
# Bendy Blog - Environment Variables
# Copy this file to .env.local and fill in
# ========================================

# --- GitHub OAuth App ---
# Create at: https://github.com/settings/developers
# Callback URL: https://your-domain.com/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# --- GitHub Content Repo ---
# A repo to store blog markdown files (e.g. your-name/blog-content)
# Create a Personal Access Token with repo write access
GITHUB_CONTENT_REPO=your-username/your-blog-content
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=run-openssl-rand-base64-32

# --- PostgreSQL ---
# Neon / Supabase / Vercel Postgres / Railway
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Upstash Redis ---
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx

# --- Admin ---
# Comma-separated GitHub usernames
ADMIN_GITHUB_USERNAMES=your-github-username

# --- Image Storage (Optional, also configurable in admin Settings) ---
# Dufs file server (priority if enabled)
DUFS_ENABLED=false
DUFS_URL=
DUFS_USER=
DUFS_PASS=

# GitHub image repo (fallback)
GITHUB_IMAGE_REPO=your-username/blog-images
GITHUB_IMAGE_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# --- SMTP (Optional) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
