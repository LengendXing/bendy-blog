# GitHub OAuth (create at https://github.com/settings/apps)
GITHUB_ID=
GITHUB_SECRET=

# GitHub Content Repo (owner/repo format)
GITHUB_CONTENT_REPO=your-username/your-blog-content
GITHUB_TOKEN=

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret

# PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Admin GitHub username(s), comma separated
ADMIN_GITHUB_USERNAMES=your-github-username

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
